# === Telegram ===
# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...
# Секретная строка для защиты вебхука (придумай любую)
WEBHOOK_SECRET=super-secret-string
# Публичный URL сервиса на Render, например https://candy-bot.onrender.com
PUBLIC_URL=https://candy-bot.onrender.com
# ID админа (твой Telegram user id) — кому приходят заказы и кто имеет доступ к /admin.
# Можно указать несколько через запятую: 111111111,222222222
ADMIN_CHAT_ID=111111111

# === Supabase ===
SUPABASE_URL=https://xxxx.supabase.co
# service_role ключ (только на сервере, никогда не на клиенте!)
SUPABASE_SERVICE_KEY=eyJ...

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=123456789
CLOUDINARY_API_SECRET=abcdef...

# === Прочее ===
PORT=3000

# (опционально) для локального теста Mini App без Telegram — ваш tg id
# DEV_TG_ID=123456789

# === Публічний сайт (WowSmak) ===
# Базовий URL сайту для canonical/sitemap/OG. Якщо порожній — береться PUBLIC_URL.
SITE_URL=https://candy-bot.onrender.com

# Бренд / контакти (для SEO та локального пошуку)
SHOP_NAME=WowSmak
SHOP_TAGLINE=Магазин солодощів та конфет з доставкою
SHOP_DESCRIPTION=
SHOP_KEYWORDS=
SHOP_PHONE=+380 00 000 00 00
SHOP_EMAIL=hello@wowsmak.com.ua
SHOP_CITY=Одеса
SHOP_REGION=Одеська область
SHOP_COUNTRY=UA
# SHOP_STREET=
# SHOP_POSTAL_CODE=
# SHOP_GEO_LAT=
# SHOP_GEO_LNG=
SHOP_HOURS=Mo-Su 09:00-21:00

# Соцмережі / месенджери
# Посилання на бота (кнопка "Купити в Telegram")
TELEGRAM_BOT_URL=https://t.me/YourBot
BOT_USERNAME=WowSmakBot
# SHOP_INSTAGRAM=https://instagram.com/...
# SHOP_FACEBOOK=https://facebook.com/...

# Аналітика та верифікація (для просування)
GA_ID=
META_PIXEL_ID=
GOOGLE_SITE_VERIFICATION=

# Безкоштовна доставка від суми (0 = вимкнено)
FREE_SHIPPING_FROM=0
